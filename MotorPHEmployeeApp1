    addEmployeeNameField = UIComponentFactory.createStyledTextField(20);
    addBasicSalaryField  = UIComponentFactory.createStyledTextField(12);
    addHourlyRateField   = UIComponentFactory.createStyledTextField(12);
    addEmployeeButton    = UIComponentFactory.createPrimaryButton(
        AppConstants.BUTTON_ADD_EMPLOYEE);
    JButton clearAddFieldsButton = UIComponentFactory.createSecondaryButton(
