    if (!EmployeeData.getLastFileError().isEmpty()) {
      JOptionPane.showMessageDialog(null,
          "Warning: " + EmployeeData.getLastFileError()
          + "\nDefault employees loaded instead.",
          AppConstants.DIALOG_FILE_ERROR, JOptionPane.WARNING_MESSAGE);
    }

    JFrame mainFrame = new JFrame(AppConstants.APP_TITLE);
    mainFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
    mainFrame.setSize(AppConstants.WINDOW_WIDTH, AppConstants.WINDOW_HEIGHT);
    mainFrame.setLocationRelativeTo(null);

    JTabbedPane navigationTabs = new JTabbedPane();
    navigationTabs.setFont(AppConstants.FONT_LABEL);
    navigationTabs.addTab(AppConstants.TAB_PAYROLL,       buildPayrollTab());
    navigationTabs.addTab(AppConstants.TAB_VIEW_ADD,      buildViewAddTab());
    navigationTabs.addTab(AppConstants.TAB_UPDATE_DELETE, buildUpdateDeleteTab());
    navigationTabs.addTab(AppConstants.TAB_SUMMARY,       buildSummaryTab());

    mainFrame.add(UIComponentFactory.createAppHeaderBanner(), BorderLayout.NORTH);
    mainFrame.add(navigationTabs, BorderLayout.CENTER);
    mainFrame.setVisible(true);
  }

