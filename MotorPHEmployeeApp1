  private static JTextField payrollEmployeeIdField;
  private static JTextField payCoverageStartField;
  private static JTextField payCoverageEndField;
  private static JButton    computePayrollButton;
  private static JTextArea  payrollResultArea;

  // ── CR02 — View/Add Tab ─────────────────────────────────────────────────────
  private static JTextArea  allEmployeesDisplayArea;
  private static JTextField addEmployeeIdField;
  private static JTextField addEmployeeNameField;
  private static JTextField addBasicSalaryField;
  private static JTextField addHourlyRateField;
  private static JButton    addEmployeeButton;

  // ── CR04 — Update/Delete Tab ────────────────────────────────────────────────
  private static JTextField searchEmployeeIdField;
  private static JTextField updateEmployeeNameField;
  private static JTextField updateBasicSalaryField;
  private static JTextField updateHourlyRateField;
  private static JButton    saveChangesButton;
  private static JButton    deleteEmployeeButton;
  private static JTextArea  updateStatusArea;

  // ── CR05 — Summary Tab ──────────────────────────────────────────────────────
  private static JTextArea payrollSummaryArea;

  // ────────────────────────────────────────────────────────────────────────────

  public static void main(String[] args) {
    SwingUtilities.invokeLater(MotorPHEmployeeApp::initializeAndDisplayGui);
  }

  /** Initializes the main window, builds all tabs, then makes it visible. */
  public static void initializeAndDisplayGui() {
    applySystemLookAndFeel();

    JFrame mainFrame = new JFrame(AppConstants.APP_TITLE);
    mainFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
    mainFrame.setSize(AppConstants.WINDOW_WIDTH, AppConstants.WINDOW_HEIGHT);
    mainFrame.setLocationRelativeTo(null);

    JTabbedPane navigationTabs = new JTabbedPane();
    navigationTabs.setFont(AppConstants.FONT_LABEL);
    navigationTabs.addTab(AppConstants.TAB_PAYROLL,       buildPayrollTab());
    navigationTabs.addTab(AppConstants.TAB_VIEW_ADD,      buildViewAddTab());
    navigationTabs.addTab(AppConstants.TAB_UPDATE_DELETE, buildUpdateDeleteTab());
    navigationTabs.addTab(AppConstants.TAB_SUMMARY,       buildSummaryTab());

    mainFrame.add(UIComponentFactory.createAppHeaderBanner(), BorderLayout.NORTH);
    mainFrame.add(navigationTabs, BorderLayout.CENTER);
    mainFrame.setVisible(true);
  }

  // ── Tab Builders ─────────────────────────────────────────────────────────────

  /**
   * CR01 + CR03 — Payroll computation tab.
   * Required inputs: Employee Number, Employee Name (auto-displayed), Pay Coverage.
   */
  private static JPanel buildPayrollTab() {
    JPanel outerPanel = createTabOuterPanel();

    // ── Input section ──
    JPanel inputSection = UIComponentFactory.createSectionPanel(
        AppConstants.SECTION_COMPUTE_PAYROLL);

    payrollEmployeeIdField = UIComponentFactory.createStyledTextField(14);
    payCoverageStartField  = UIComponentFactory.createStyledTextField(12);
    payCoverageEndField    = UIComponentFactory.createStyledTextField(12);
    computePayrollButton   = UIComponentFactory.createPrimaryButton(
        AppConstants.BUTTON_COMPUTE_PAYROLL);
    JButton resetPayrollButton = UIComponentFactory.createSecondaryButton(
        AppConstants.BUTTON_RESET);
    computePayrollButton.setEnabled(false); // error prevention: disabled until all fields filled

    // Row 1: Employee Number
    JPanel employeeIdRow = createFlowRow();
    employeeIdRow.add(UIComponentFactory.createFieldLabel(AppConstants.LABEL_EMPLOYEE_ID));
    employeeIdRow.add(payrollEmployeeIdField);

    // Row 2: Pay Coverage
    JPanel payCoverageRow = createFlowRow();
    payCoverageRow.add(UIComponentFactory.createFieldLabel(
        AppConstants.LABEL_PAY_PERIOD_START));
    payCoverageRow.add(payCoverageStartField);
    payCoverageRow.add(Box.createHorizontalStrut(12));
    payCoverageRow.add(UIComponentFactory.createFieldLabel(
        AppConstants.LABEL_PAY_PERIOD_END));
    payCoverageRow.add(payCoverageEndField);

    // Row 3: Buttons
    JPanel buttonRow = createFlowRow();
    buttonRow.add(computePayrollButton);
    buttonRow.add(resetPayrollButton);

    inputSection.add(employeeIdRow);
    inputSection.add(Box.createVerticalStrut(6));
    inputSection.add(payCoverageRow);
    inputSection.add(Box.createVerticalStrut(4));
    inputSection.add(buttonRow);
    inputSection.add(Box.createVerticalStrut(2));
    inputSection.add(UIComponentFactory.createHintLabel(AppConstants.HINT_AVAILABLE_IDS));
    inputSection.add(UIComponentFactory.createHintLabel(AppConstants.HINT_DATE_FORMAT));

    // ── Result section ──
    JPanel resultSection = UIComponentFactory.createSectionPanel(
        AppConstants.SECTION_PAYROLL_RESULT);
    payrollResultArea = UIComponentFactory.createReadOnlyResultArea(
        AppConstants.RESULT_AREA_ROWS);
    payrollResultArea.setText(AppConstants.HINT_PAYROLL_INITIAL);
    resultSection.add(new JScrollPane(payrollResultArea));

    outerPanel.add(inputSection,  BorderLayout.NORTH);
    outerPanel.add(resultSection, BorderLayout.CENTER);

    // Events — enable Compute only when all 3 fields are filled
    DocumentListener allPayrollFieldsListener = buildAllFieldsRequiredListener(
        computePayrollButton,
        payrollEmployeeIdField, payCoverageStartField, payCoverageEndField);
    payrollEmployeeIdField.getDocument().addDocumentListener(allPayrollFieldsListener);
    payCoverageStartField.getDocument().addDocumentListener(allPayrollFieldsListener);
    payCoverageEndField.getDocument().addDocumentListener(allPayrollFieldsListener);

    computePayrollButton.addActionListener(e -> handleComputePayroll());
    resetPayrollButton.addActionListener(e -> clearPayrollTab());
    payrollEmployeeIdField.addActionListener(e -> {
      if (computePayrollButton.isEnabled()) handleComputePayroll();
    });

    return outerPanel;
  }

