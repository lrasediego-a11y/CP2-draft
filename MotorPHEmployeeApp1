  private static void handleComputePayroll() {
    String enteredEmployeeId = payrollEmployeeIdField.getText().trim();
    String enteredStartDate  = payCoverageStartField.getText().trim();
    String enteredEndDate    = payCoverageEndField.getText().trim();

    try {
      if (!InputValidator.validatePayrollInputFields(
          enteredEmployeeId, enteredStartDate, enteredEndDate)) {
        throw new IllegalArgumentException(InputValidator.getLastValidationError());
      }

      int    employeeIndex   = EmployeeData.findEmployeeIndexById(enteredEmployeeId);
      String employeeName    = EmployeeData.getEmployeeNameByIndex(employeeIndex);
      String department      = EmployeeData.getDepartmentByIndex(employeeIndex);
      String position        = EmployeeData.getPositionByIndex(employeeIndex);
      double basicSalary     = EmployeeData.getBasicSalaryByIndex(employeeIndex);
      double hourlyRate      = EmployeeData.getHourlyRateByIndex(employeeIndex);
      double hoursWorked     = TimeRecordData.computeHoursWorkedInPayPeriod(
          enteredEmployeeId, enteredStartDate, enteredEndDate);
      double grossPay        = PayrollCalculator.computeGrossPay(hourlyRate, hoursWorked);
      double totalDeductions = PayrollCalculator.computeAllDeductions(grossPay, basicSalary);
      double netPay          = PayrollCalculator.computeNetPay(grossPay, totalDeductions);
      String attendanceSummary = TimeRecordData.buildAttendanceSummaryForPayPeriod(
          enteredEmployeeId, enteredStartDate, enteredEndDate);

      String formattedReport = PayrollReportBuilder.buildIndividualPayrollReport(
          enteredEmployeeId, employeeName, department, position,
          enteredStartDate, enteredEndDate,
          basicSalary, hourlyRate, hoursWorked,
          grossPay,
          PayrollCalculator.getLastSssContribution(),
          PayrollCalculator.getLastPhilHealthContribution(),
          PayrollCalculator.getLastPagIbigContribution(),
          PayrollCalculator.getLastWithholdingTax(),
          totalDeductions, netPay, attendanceSummary);

      payrollResultArea.setText(formattedReport);

    } catch (IllegalArgumentException validationException) {
      showWarningDialog(validationException.getMessage(), AppConstants.DIALOG_INPUT_ERROR);
      payrollResultArea.setText(validationException.getMessage());
    } catch (Exception unexpectedException) {
      showErrorDialog("Something went wrong. Please try again.");
    }
  }

  private static void clearPayrollTab() {
