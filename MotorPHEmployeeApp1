import javax.swing.*;
import javax.swing.event.DocumentEvent;
import javax.swing.event.DocumentListener;
import java.awt.*;

/**
 * MotorPHEmployeeApp
 *
 * Main entry point and GUI controller for the MotorPH Employee App.
 * Implements MPHCR01 – Feature 1: Graphical User Interface with
 * Employee Number, Employee Name, and Pay Coverage input fields.
 *
 * Architecture (MVC-like):
 *   View    — Swing components built via UIComponentFactory
 *   Model   — EmployeeData, TimeRecordData, PayrollCalculator
 *   Control — handleXxx() event handler methods in this class
 *
 * All magic numbers/strings come from AppConstants.
 * All component creation goes through UIComponentFactory (Factory pattern).
 * All report text is built by PayrollReportBuilder (single responsibility).
 */
public class MotorPHEmployeeApp {

