    payrollResultArea.setText(AppConstants.HINT_PAYROLL_CLEARED);
  }

  /** Feature 2 — Validates and adds new employee, then saves to CSV. */
  private static void handleAddNewEmployee() {
    String newId         = addEmployeeIdField.getText().trim();
    String newName       = addEmployeeNameField.getText().trim();
    String newDepartment = addDepartmentField.getText().trim();
    String newPosition   = addPositionField.getText().trim();
    String newSalary     = addBasicSalaryField.getText().trim();
    String newRate       = addHourlyRateField.getText().trim();

    try {
      if (!InputValidator.validateNewEmployeeFields(
          newId, newName, newDepartment, newPosition, newSalary, newRate)) {
        throw new IllegalArgumentException(InputValidator.getLastValidationError());
      }

      double parsedSalary = Double.parseDouble(newSalary);
      double parsedRate   = Double.parseDouble(newRate);

      boolean addSuccess = EmployeeData.addNewEmployee(
          newId, newName, newDepartment, newPosition, parsedSalary, parsedRate);

      if (!addSuccess) {
        throw new IllegalArgumentException(
            !EmployeeData.getLastFileError().isEmpty()
            ? EmployeeData.getLastFileError()
            : "Could not add employee. ID may already exist.");
      }

      JOptionPane.showMessageDialog(null,
          "Employee " + newId + " — " + newName + " has been added and saved to CSV.",
          AppConstants.DIALOG_ADDED, JOptionPane.INFORMATION_MESSAGE);

      clearAddEmployeeFields();
      refreshAllEmployeesDisplay();

    } catch (IllegalArgumentException validationException) {
      showWarningDialog(validationException.getMessage(), AppConstants.DIALOG_INPUT_ERROR);
    } catch (Exception unexpectedException) {
      showErrorDialog("Something went wrong. Please try again.");
    }
  }

  /** Feature 4 — Loads an employee into the edit fields for update/delete. */
  private static void handleLoadEmployeeForEditing() {
    String targetEmployeeId = searchEmployeeIdField.getText().trim();

    try {
      if (!InputValidator.validateEmployeeIdNotEmpty(targetEmployeeId)) {
        throw new IllegalArgumentException(InputValidator.getLastValidationError());
      }
      if (!InputValidator.validateEmployeeIdExists(targetEmployeeId)) {
        throw new IllegalArgumentException(InputValidator.getLastValidationError());
      }

      int employeeIndex = EmployeeData.findEmployeeIndexById(targetEmployeeId);
      updateEmployeeNameField.setText(EmployeeData.getEmployeeNameByIndex(employeeIndex));
      updateDepartmentField.setText(EmployeeData.getDepartmentByIndex(employeeIndex));
      updatePositionField.setText(EmployeeData.getPositionByIndex(employeeIndex));
      updateBasicSalaryField.setText(
          String.valueOf(EmployeeData.getBasicSalaryByIndex(employeeIndex)));
      updateHourlyRateField.setText(
          String.valueOf(EmployeeData.getHourlyRateByIndex(employeeIndex)));
      enableEditFields();

      updateStatusArea.setText(
          "Employee Number " + targetEmployeeId + " loaded.\n"
          + "Edit the fields above, then click Save Changes or Delete Employee.");

    } catch (IllegalArgumentException validationException) {
      showWarningDialog(validationException.getMessage(), AppConstants.DIALOG_NOT_FOUND);
    }
  }

  /** Feature 4 — Validates and saves updated employee record to CSV. */
  private static void handleSaveEmployeeChanges() {
    String targetEmployeeId   = searchEmployeeIdField.getText().trim();
    String updatedName        = updateEmployeeNameField.getText().trim();
    String updatedDepartment  = updateDepartmentField.getText().trim();
    String updatedPosition    = updatePositionField.getText().trim();
    String updatedSalaryInput = updateBasicSalaryField.getText().trim();
    String updatedRateInput   = updateHourlyRateField.getText().trim();

    try {
      if (targetEmployeeId.isEmpty()) {
        throw new IllegalArgumentException("Please load an employee record first.");
      }
      if (!InputValidator.validateUpdateEmployeeFields(
          updatedName, updatedDepartment, updatedPosition,
          updatedSalaryInput, updatedRateInput)) {
        throw new IllegalArgumentException(InputValidator.getLastValidationError());
      }

      double updatedSalary = Double.parseDouble(updatedSalaryInput);
      double updatedRate   = Double.parseDouble(updatedRateInput);

      boolean updateSuccess = EmployeeData.updateExistingEmployee(
          targetEmployeeId, updatedName, updatedDepartment,
          updatedPosition, updatedSalary, updatedRate);

      if (!updateSuccess) {
        throw new IllegalArgumentException(
            !EmployeeData.getLastFileError().isEmpty()
            ? EmployeeData.getLastFileError()
            : "Could not update employee.");
      }

      JOptionPane.showMessageDialog(null,
          "Employee " + targetEmployeeId + " updated and saved to CSV.",
          AppConstants.DIALOG_UPDATED, JOptionPane.INFORMATION_MESSAGE);

      updateStatusArea.setText(
          "Updated Employee Number : " + targetEmployeeId
          + "\n  Name       : " + updatedName
          + "\n  Department : " + updatedDepartment
          + "\n  Position   : " + updatedPosition
          + "\n  Salary     : PHP " + String.format("%,.2f", updatedSalary)
          + "\n  Rate       : PHP " + String.format("%,.2f", updatedRate));

    } catch (IllegalArgumentException validationException) {
      showWarningDialog(validationException.getMessage(), AppConstants.DIALOG_INPUT_ERROR);
    } catch (Exception unexpectedException) {
      showErrorDialog("Something went wrong. Please try again.");
    }
  }

  /** Feature 4 — Confirms and deletes the selected employee record from CSV. */
  private static void handleDeleteEmployee() {
    String targetEmployeeId = searchEmployeeIdField.getText().trim();

    try {
      if (targetEmployeeId.isEmpty()) {
        throw new IllegalArgumentException("Please load an employee record first.");
      }
      if (!InputValidator.validateEmployeeIdExists(targetEmployeeId)) {
        throw new IllegalArgumentException(InputValidator.getLastValidationError());
      }

      int    employeeIndex = EmployeeData.findEmployeeIndexById(targetEmployeeId);
      String employeeName  = EmployeeData.getEmployeeNameByIndex(employeeIndex);

      int userConfirmation = JOptionPane.showConfirmDialog(null,
          "You are about to permanently delete:\n\n"
          + "  Employee Number : " + targetEmployeeId + "\n"
          + "  Name            : " + employeeName + "\n\n"
          + "This action cannot be undone. Continue?",
          AppConstants.DIALOG_CONFIRM_DELETE,
          JOptionPane.YES_NO_OPTION, JOptionPane.WARNING_MESSAGE);

      if (userConfirmation == JOptionPane.YES_OPTION) {
        boolean deleteSuccess = EmployeeData.deleteEmployeeById(targetEmployeeId);

        if (!deleteSuccess) {
          throw new IllegalArgumentException(
              !EmployeeData.getLastFileError().isEmpty()
              ? EmployeeData.getLastFileError()
              : "Could not delete employee.");
        }

        JOptionPane.showMessageDialog(null,
            "Employee " + targetEmployeeId + " — " + employeeName
            + " has been removed and CSV updated.",
            AppConstants.DIALOG_DELETED, JOptionPane.INFORMATION_MESSAGE);

        clearUpdateDeleteTab();
        updateStatusArea.setText(
            "Employee " + targetEmployeeId
            + " (" + employeeName + ") has been deleted.");
      }

    } catch (IllegalArgumentException validationException) {
      showWarningDialog(validationException.getMessage(), AppConstants.DIALOG_INPUT_ERROR);
    } catch (Exception unexpectedException) {
      showErrorDialog("Something went wrong. Please try again.");
    }
  }

  /**
   * Feature 3 — Uses array-based PayrollCalculator methods to compute
   * payroll for ALL employees at once, then displays the summary report.
   */
  private static void handleGeneratePayrollSummary() {
    try {
      String[] allEmployeeIds = EmployeeData.getAllEmployeeIds();
      if (allEmployeeIds.length == 0) {
        payrollSummaryArea.setText(
            "No employee records found. Please add employees first.");
        return;
      }

      int totalEmployees = allEmployeeIds.length;

      // Build parallel arrays for Feature 3 array-based computation
      String[] allNames        = new String[totalEmployees];
      String[] allDepartments  = new String[totalEmployees];
      String[] allPositions    = new String[totalEmployees];
      double[] allHourlyRates  = new double[totalEmployees];
      double[] allBasicSalaries = new double[totalEmployees];
      double[] allHoursWorked  = new double[totalEmployees];

      for (int i = 0; i < totalEmployees; i++) {
        int employeeIndex         = EmployeeData.findEmployeeIndexById(allEmployeeIds[i]);
        allNames[i]               = EmployeeData.getEmployeeNameByIndex(employeeIndex);
        allDepartments[i]         = EmployeeData.getDepartmentByIndex(employeeIndex);
        allPositions[i]           = EmployeeData.getPositionByIndex(employeeIndex);
        allHourlyRates[i]         = EmployeeData.getHourlyRateByIndex(employeeIndex);
        allBasicSalaries[i]       = EmployeeData.getBasicSalaryByIndex(employeeIndex);
        allHoursWorked[i]         = TimeRecordData.computeTotalHoursWorked(allEmployeeIds[i]);
      }

      // Feature 3: array-based computation via PayrollCalculator
      double[] allGrossPays   = PayrollCalculator.computeAllGrossPays(
          allHourlyRates, allHoursWorked);
      double[] allDeductions  = PayrollCalculator.computeAllDeductionsArray(
          allGrossPays, allBasicSalaries);
      double[] allNetPays     = PayrollCalculator.computeAllNetPays(
          allGrossPays, allDeductions);

      double totalGrossPay    = PayrollCalculator.computeArrayTotal(allGrossPays);
      double totalDeductions  = PayrollCalculator.computeArrayTotal(allDeductions);
      double totalNetPay      = PayrollCalculator.computeArrayTotal(allNetPays);
      double averageNetPay    = PayrollCalculator.computeArrayAverage(allNetPays);

      payrollSummaryArea.setText(PayrollReportBuilder.buildPayrollSummaryReport(
          allEmployeeIds, allNames, allDepartments, allPositions,
          allGrossPays, allDeductions, allNetPays,
          totalGrossPay, totalDeductions, totalNetPay, averageNetPay));

    } catch (Exception unexpectedException) {
      showErrorDialog("Could not generate the summary. Please try again.");
    }
  }

