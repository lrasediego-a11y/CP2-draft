/**
 * PayrollCalculator
 *
 * Computation layer for all payroll-related calculations (Feature 3).
 * Implements CP1 MotorPH formulas for gross pay, SSS, PhilHealth,
 * Pag-IBIG, withholding tax, total deductions, and net pay.
 *
 * Uses arrays to store and process multiple employee salary values
 * for the payroll summary (Feature 3 — Salary Computation).
 *
 * All bracket values and rates are pulled from AppConstants —
 * no magic numbers appear in this class.
 *
 * After calling computeAllDeductions(), use the individual getters
 * to retrieve itemized deduction amounts for display.
 */
public class PayrollCalculator {

  private static double lastSssContribution;
  private static double lastPhilHealthContribution;
  private static double lastPagIbigContribution;
  private static double lastWithholdingTax;
  private static double lastTotalDeductions;

  private PayrollCalculator() {}

  // ── Primary Computation Methods ─────────────────────────────────────────────

  public static double computeGrossPay(double hourlyRate, double hoursWorked) {
    return hourlyRate * hoursWorked;
  }

  public static double computeAllDeductions(double grossPayAmount, double basicSalaryAmount) {
    lastSssContribution        = computeSssContribution(basicSalaryAmount);
    lastPhilHealthContribution = computePhilHealthContribution(basicSalaryAmount);
    lastPagIbigContribution    = computePagIbigContribution(basicSalaryAmount);

    double totalGovernmentContributions =
        lastSssContribution + lastPhilHealthContribution + lastPagIbigContribution;

    double taxableIncome = grossPayAmount - totalGovernmentContributions;
    lastWithholdingTax   = computeWithholdingTax(taxableIncome);

    lastTotalDeductions = totalGovernmentContributions + lastWithholdingTax;
    return lastTotalDeductions;
  }

  public static double computeNetPay(double grossPayAmount, double totalDeductionsAmount) {
    return grossPayAmount - totalDeductionsAmount;
  }

  // ── Feature 3: Array-Based Salary Computation ───────────────────────────────

  /**
   * Computes gross pay for all employees and returns the results as an array.
   * Used in the Summary tab to process all records at once.
   *
   * @param hourlyRates  array of hourly rates, one per employee
   * @param hoursWorked  array of total hours worked, one per employee
   * @return array of gross pay values
   */
  public static double[] computeAllGrossPays(double[] hourlyRates, double[] hoursWorked) {
    double[] grossPays = new double[hourlyRates.length];
    for (int i = 0; i < hourlyRates.length; i++) {
      grossPays[i] = computeGrossPay(hourlyRates[i], hoursWorked[i]);
    }
    return grossPays;
  }

  /**
   * Computes total deductions for all employees and returns the results as an array.
   *
   * @param grossPays     array of gross pay values
   * @param basicSalaries array of basic salary values
   * @return array of total deduction values
   */
  public static double[] computeAllDeductionsArray(
      double[] grossPays, double[] basicSalaries) {
    double[] allDeductions = new double[grossPays.length];
    for (int i = 0; i < grossPays.length; i++) {
      allDeductions[i] = computeAllDeductions(grossPays[i], basicSalaries[i]);
    }
    return allDeductions;
  }

  /**
   * Computes net pay for all employees from gross pay and deductions arrays.
   *
   * @param grossPays    array of gross pay values
   * @param allDeductions array of total deduction values
   * @return array of net pay values
   */
  public static double[] computeAllNetPays(double[] grossPays, double[] allDeductions) {
    double[] netPays = new double[grossPays.length];
    for (int i = 0; i < grossPays.length; i++) {
      netPays[i] = computeNetPay(grossPays[i], allDeductions[i]);
    }
    return netPays;
  }

  /**
   * Sums all values in a double array.
   * Used to compute total gross pay, total deductions, total net pay.
   *
   * @param values array of numeric values
   * @return the total sum
   */
  public static double computeArrayTotal(double[] values) {
    double total = 0;
    for (int i = 0; i < values.length; i++) {
      total += values[i];
    }
    return total;
  }

  /**
   * Computes the average of all values in a double array.
   *
   * @param values array of numeric values
   * @return the average, or 0 if the array is empty
   */
  public static double computeArrayAverage(double[] values) {
    if (values.length == 0) {
      return 0;
    }
    return computeArrayTotal(values) / values.length;
  }

  // ── Government Contribution Formulas ───────────────────────────────────────

  public static double computeSssContribution(double basicSalaryAmount) {
    if (basicSalaryAmount < AppConstants.SSS_BRACKET_FLOOR_START) {
      return AppConstants.SSS_MINIMUM_CONTRIBUTION;
    }
    if (basicSalaryAmount >= AppConstants.SSS_BRACKET_MAX_SALARY) {
      return AppConstants.SSS_MAXIMUM_CONTRIBUTION;
    }
    double bracketFloor        = AppConstants.SSS_BRACKET_FLOOR_START;
    double bracketCeiling      = AppConstants.SSS_BRACKET_CEILING_START;
    double bracketContribution = AppConstants.SSS_CONTRIBUTION_START;

    while (bracketCeiling <= AppConstants.SSS_BRACKET_MAX_SALARY) {
      if (basicSalaryAmount >= bracketFloor && basicSalaryAmount < bracketCeiling) {
        return bracketContribution;
      }
      bracketFloor        += AppConstants.SSS_BRACKET_STEP;
      bracketCeiling      += AppConstants.SSS_BRACKET_STEP;
      bracketContribution += AppConstants.SSS_CONTRIBUTION_INCREMENT;
    }
    return bracketContribution;
  }

  public static double computePhilHealthContribution(double basicSalaryAmount) {
    double monthlyPremium;
    if (basicSalaryAmount < AppConstants.PHILHEALTH_MIN_SALARY) {
      monthlyPremium = AppConstants.PHILHEALTH_MIN_PREMIUM;
    } else if (basicSalaryAmount <= AppConstants.PHILHEALTH_MAX_SALARY) {
      monthlyPremium = basicSalaryAmount * AppConstants.PHILHEALTH_PREMIUM_RATE;
    } else {
      monthlyPremium = AppConstants.PHILHEALTH_MAX_PREMIUM;
    }
    return monthlyPremium * AppConstants.PHILHEALTH_EMPLOYEE_SHARE;
  }

  public static double computePagIbigContribution(double basicSalaryAmount) {
    double applicableRate =
        (basicSalaryAmount >= AppConstants.PAG_IBIG_SALARY_LOWER
            && basicSalaryAmount <= AppConstants.PAG_IBIG_SALARY_UPPER)
        ? AppConstants.PAG_IBIG_RATE_LOW
        : AppConstants.PAG_IBIG_RATE_STANDARD;

    double computedContribution = basicSalaryAmount * applicableRate;
    return Math.min(computedContribution, AppConstants.PAG_IBIG_MAX_CONTRIBUTION);
  }

  public static double computeWithholdingTax(double taxableIncomeAmount) {
    if (taxableIncomeAmount <= AppConstants.TAX_EXEMPT_CEILING) {
      return 0.00;
    }
    if (taxableIncomeAmount < AppConstants.TAX_BRACKET_2_CEILING) {
      return (taxableIncomeAmount - AppConstants.TAX_BRACKET_2_FLOOR)
          * AppConstants.TAX_BRACKET_2_RATE;
    }
    if (taxableIncomeAmount < AppConstants.TAX_BRACKET_3_CEILING) {
      return AppConstants.TAX_BRACKET_2_BASE
          + (taxableIncomeAmount - AppConstants.TAX_BRACKET_3_FLOOR)
          * AppConstants.TAX_BRACKET_3_RATE;
    }
    if (taxableIncomeAmount < AppConstants.TAX_BRACKET_4_CEILING) {
      return AppConstants.TAX_BRACKET_3_BASE
          + (taxableIncomeAmount - AppConstants.TAX_BRACKET_4_FLOOR)
          * AppConstants.TAX_BRACKET_4_RATE;
    }
    if (taxableIncomeAmount < AppConstants.TAX_BRACKET_5_CEILING) {
      return AppConstants.TAX_BRACKET_4_BASE
          + (taxableIncomeAmount - AppConstants.TAX_BRACKET_5_FLOOR)
          * AppConstants.TAX_BRACKET_5_RATE;
    }
    return AppConstants.TAX_BRACKET_5_BASE
        + (taxableIncomeAmount - AppConstants.TAX_BRACKET_6_FLOOR)
        * AppConstants.TAX_BRACKET_6_RATE;
  }

  // ── Itemized Deduction Getters ──────────────────────────────────────────────

  public static double getLastSssContribution()        { return lastSssContribution; }
  public static double getLastPhilHealthContribution() { return lastPhilHealthContribution; }
  public static double getLastPagIbigContribution()    { return lastPagIbigContribution; }
  public static double getLastWithholdingTax()         { return lastWithholdingTax; }
  public static double getLastTotalDeductions()        { return lastTotalDeductions; }
}
