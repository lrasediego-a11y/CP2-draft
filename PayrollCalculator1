public class PayrollCalculator {
    private static double grossPay;
    private static double sssContribution;
    private static double philHealthContribution;
    private static double pagIbigContribution;
    private static double withholdingTax;
    private static double totalDeductions;
    private static double netPay;

    public static double computeGrossPay(double hourlyRate, double hoursWorked) {
        grossPay = hourlyRate * hoursWorked;
        System.out.println("Gross pay computed: " + grossPay);
        return grossPay;
    }

    public static double computeDeductions(double grossPayValue, double basicSalary) {
        sssContribution = computeSSS(basicSalary);
        philHealthContribution = computePhilHealth(basicSalary);
        pagIbigContribution = computePagIbig(basicSalary);

        double governmentContributions = sssContribution + philHealthContribution + pagIbigContribution;
        double taxableIncome = grossPayValue - governmentContributions;
        withholdingTax = computeWithholdingTax(taxableIncome);

        totalDeductions = governmentContributions + withholdingTax;
        System.out.println("Total deductions computed: " + totalDeductions);
        return totalDeductions;
    }

    public static double computeNetPay(double grossPayValue, double deductionsValue) {
        netPay = grossPayValue - deductionsValue;
        System.out.println("Net pay computed: " + netPay);
        return netPay;
    }

    public static double computeSSS(double basicSalary) {
        if (basicSalary < 3250) {
            return 135.00;
        }

        if (basicSalary >= 24750) {
            return 1125.00;
        }

        double bracketFloor = 3250;
        double bracketCeiling = 3750;
        double bracketContribution = 157.50;

        while (bracketCeiling <= 24750) {
            if (basicSalary >= bracketFloor && basicSalary < bracketCeiling) {
                return bracketContribution;
            }

            bracketFloor += 500;
            bracketCeiling += 500;
            bracketContribution += 22.50;
        }

        return bracketContribution;
    }

    public static double computePhilHealth(double basicSalary) {
        double monthlyPremium;

        if (basicSalary < 10000) {
            monthlyPremium = 300.00;
        } else if (basicSalary <= 59999.99) {
            monthlyPremium = basicSalary * 0.03;
        } else {
            monthlyPremium = 1800.00;
        }

        return monthlyPremium / 2;
    }

    public static double computePagIbig(double basicSalary) {
        double employeeRate;

        if (basicSalary >= 1000 && basicSalary <= 1500) {
            employeeRate = 0.01;
        } else {
            employeeRate = 0.02;
        }

        double contribution = basicSalary * employeeRate;
        return Math.min(contribution, 100.00);
    }

    public static double computeWithholdingTax(double taxableIncome) {
        if (taxableIncome <= 20832) {
            return 0.00;
        } else if (taxableIncome < 33333) {
            return (taxableIncome - 20833) * 0.20;
        } else if (taxableIncome < 66667) {
            return 2500 + (taxableIncome - 33333) * 0.25;
        } else if (taxableIncome < 166667) {
            return 10833 + (taxableIncome - 66667) * 0.30;
        } else if (taxableIncome < 666667) {
            return 40833.33 + (taxableIncome - 166667) * 0.32;
        } else {
            return 200833.33 + (taxableIncome - 666667) * 0.35;
        }
    }

    public static double getSSSContribution() {
        return sssContribution;
    }

    public static double getPhilHealthContribution() {
        return philHealthContribution;
    }

    public static double getPagIbigContribution() {
        return pagIbigContribution;
    }

    public static double getWithholdingTax() {
        return withholdingTax;
    }
}
