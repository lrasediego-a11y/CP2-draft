/**
 * TimeRecordData
 *
 * Data layer for employee attendance and time records.
 * Supports filtering hours by pay coverage date range (start to end date).
 * Uses constants from AppConstants to avoid hard-coded values.
 */
public class TimeRecordData {

  private static final String[] employeeIdRecords    = AppConstants.DEFAULT_TIME_IDS;
  private static final String[] attendanceDateRecords = AppConstants.DEFAULT_TIME_DATES;
  private static final double[] hoursWorkedRecords   = AppConstants.DEFAULT_HOURS_WORKED;

  private TimeRecordData() {}

  /**
   * Computes total hours worked for an employee within a pay coverage period.
   * Only counts records where the date falls on or between startDate and endDate.
   *
   * @param targetEmployeeId  the employee ID to look up
   * @param payCoverageStart  start date of the pay period (YYYY-MM-DD)
   * @param payCoverageEnd    end date of the pay period (YYYY-MM-DD)
   * @return total hours worked within the coverage period; 0.0 if none found
   */
  public static double computeHoursWorkedInPayPeriod(
      String targetEmployeeId,
      String payCoverageStart,
      String payCoverageEnd) {

    double totalHoursWorked = 0.00;
    for (int i = 0; i < employeeIdRecords.length; i++) {
      if (employeeIdRecords[i].equals(targetEmployeeId)
          && isDateWithinRange(attendanceDateRecords[i], payCoverageStart, payCoverageEnd)) {
        totalHoursWorked += hoursWorkedRecords[i];
      }
    }
    return totalHoursWorked;
  }

  /**
   * Computes total hours worked across ALL records for an employee.
   * Used when no date filter is applied.
   *
   * @param targetEmployeeId the employee ID to look up
   * @return total hours worked; 0.0 if no records found
   */
  public static double computeTotalHoursWorked(String targetEmployeeId) {
    double totalHoursWorked = 0.00;
    for (int i = 0; i < employeeIdRecords.length; i++) {
      if (employeeIdRecords[i].equals(targetEmployeeId)) {
        totalHoursWorked += hoursWorkedRecords[i];
      }
    }
    return totalHoursWorked;
  }

  /**
   * Calculates hours worked from a time-in / time-out pair.
   * Returns 0.0 for an invalid range (time-out before time-in).
   *
   * @param timeIn  start time as decimal (e.g., 8.0 for 8:00 AM)
   * @param timeOut end time as decimal (e.g., 17.0 for 5:00 PM)
   * @return hours worked, or 0.0 for invalid range
   */
  public static double calculateHoursFromTimeRange(double timeIn, double timeOut) {
    if (timeOut < timeIn) {
      return 0.00;
    }
    return timeOut - timeIn;
  }

  /**
   * Builds a formatted attendance summary filtered by pay coverage period.
   *
   * @param targetEmployeeId  the employee ID to summarize
   * @param payCoverageStart  start date (YYYY-MM-DD)
   * @param payCoverageEnd    end date (YYYY-MM-DD)
   * @return formatted date-hours lines, or a "no records" message
   */
  public static String buildAttendanceSummaryForPayPeriod(
      String targetEmployeeId,
      String payCoverageStart,
      String payCoverageEnd) {

    StringBuilder attendanceSummary = new StringBuilder();
    for (int i = 0; i < employeeIdRecords.length; i++) {
      if (employeeIdRecords[i].equals(targetEmployeeId)
          && isDateWithinRange(attendanceDateRecords[i], payCoverageStart, payCoverageEnd)) {
        attendanceSummary
            .append("    ")
            .append(attendanceDateRecords[i])
            .append("  —  ")
            .append(hoursWorkedRecords[i])
            .append(" hours\n");
      }
    }
    if (attendanceSummary.length() == 0) {
      return "    No time records found within the selected pay coverage period.";
    }
    return attendanceSummary.toString();
  }

  /**
   * Builds a full attendance summary for an employee (no date filter).
   *
   * @param targetEmployeeId the employee ID to summarize
   * @return formatted attendance lines, or a "no records" message
   */
  public static String buildAttendanceSummary(String targetEmployeeId) {
    StringBuilder attendanceSummary = new StringBuilder();
    for (int i = 0; i < employeeIdRecords.length; i++) {
      if (employeeIdRecords[i].equals(targetEmployeeId)) {
        attendanceSummary
            .append("    ")
            .append(attendanceDateRecords[i])
            .append("  —  ")
            .append(hoursWorkedRecords[i])
            .append(" hours\n");
      }
    }
    if (attendanceSummary.length() == 0) {
      return "    No time records found for this employee.";
    }
    return attendanceSummary.toString();
  }

  // ── Private Helpers ─────────────────────────────────────────────────────────

  /**
   * Checks whether a given date string falls within the start–end range.
   * Comparison is lexicographic (valid for YYYY-MM-DD format).
   *
   * @param targetDate  the date to check (YYYY-MM-DD)
   * @param rangeStart  start of range inclusive (YYYY-MM-DD)
   * @param rangeEnd    end of range inclusive (YYYY-MM-DD)
   * @return true if targetDate is within the range
   */
  private static boolean isDateWithinRange(
      String targetDate, String rangeStart, String rangeEnd) {
    return targetDate.compareTo(rangeStart) >= 0
        && targetDate.compareTo(rangeEnd) <= 0;
  }
}
