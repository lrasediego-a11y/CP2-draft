import java.io.BufferedReader;
import java.io.File;
import java.io.FileReader;
import java.io.FileWriter;
import java.io.IOException;
import java.io.PrintWriter;
import java.util.ArrayList;

/**
 * EmployeeData
 *
 * Data layer for employee records, now backed by a CSV file (employees.csv)
 * for persistence across sessions — MPHCR02 / Feature 2.
 *
 * Storage model:
 *   - Parallel ArrayLists hold the in-memory copy of all employee fields.
 *   - On startup, loadFromCsv() reads employees.csv if it exists;
 *     otherwise the default dataset is loaded and immediately saved to CSV.
 *   - Every add/update/delete operation calls saveToCsv() right after,
 *     so the file always reflects the current in-memory state.
 *
 * All file operations use try-with-resources and report failures through
 * getLastFileError(), which the GUI layer surfaces to the user.
 */
public class EmployeeData {

  private static final ArrayList<String> employeeIdList    = new ArrayList<>();
  private static final ArrayList<String> employeeNameList  = new ArrayList<>();
  private static final ArrayList<String> departmentList    = new ArrayList<>();
  private static final ArrayList<String> positionList      = new ArrayList<>();
  private static final ArrayList<Double> basicSalaryList   = new ArrayList<>();
  private static final ArrayList<Double> hourlyRateList    = new ArrayList<>();

  private static String lastFileError = "";

  static {
    loadFromCsv();
  }

  private EmployeeData() {}

  // ── CSV Load / Save (Feature 2) ──────────────────────────────────────────────

  /**
   * Loads employee records from employees.csv into memory.
   * If the file does not exist yet, the default dataset is loaded
   * and immediately written to a brand-new employees.csv.
   */
  public static void loadFromCsv() {
    File csvFile = new File(AppConstants.EMPLOYEE_CSV_FILE);

    if (!csvFile.exists()) {
      loadDefaultEmployees();
      saveToCsv();
      return;
    }

    clearAllLists();

    try (BufferedReader reader = new BufferedReader(new FileReader(csvFile))) {
      String line;
      boolean isFirstLine = true;

      while ((line = reader.readLine()) != null) {
        if (isFirstLine) {
          isFirstLine = false;
          continue; // skip header row
        }
        if (line.trim().isEmpty()) {
          continue;
        }
        parseAndAddCsvRow(line);
      }
      lastFileError = "";

    } catch (IOException ioException) {
      lastFileError = "Could not read employees.csv: " + ioException.getMessage();
      if (employeeIdList.isEmpty()) {
        loadDefaultEmployees();
      }
    }
  }

  /**
   * Saves the current in-memory employee records to employees.csv,
   * overwriting the file with the latest data.
   *
   * @return true if the save succeeded; false if a file error occurred
   */
  public static boolean saveToCsv() {
    try (PrintWriter writer = new PrintWriter(new FileWriter(AppConstants.EMPLOYEE_CSV_FILE))) {
      writer.println(AppConstants.CSV_HEADER_ROW);

      for (int i = 0; i < employeeIdList.size(); i++) {
        writer.println(buildCsvRow(i));
      }
      lastFileError = "";
      return true;

    } catch (IOException ioException) {
      lastFileError = "Could not save to employees.csv: " + ioException.getMessage();
      return false;
    }
  }

  /** Returns the most recent file operation error, or an empty string if none. */
  public static String getLastFileError() {
    return lastFileError;
  }

  // ── Read Operations ─────────────────────────────────────────────────────────

  /**
   * Searches for an employee by ID and returns the index.
   *
   * @param targetEmployeeId the employee ID to search for
   * @return the list index, or -1 if not found
   */
  public static int findEmployeeIndexById(String targetEmployeeId) {
    for (int i = 0; i < employeeIdList.size(); i++) {
      if (employeeIdList.get(i).equals(targetEmployeeId)) {
        return i;
      }
    }
    return -1;
  }

  public static String getEmployeeNameByIndex(int employeeIndex) {
    return isValidIndex(employeeIndex) ? employeeNameList.get(employeeIndex) : "Unknown Employee";
  }

  public static String getDepartmentByIndex(int employeeIndex) {
    return isValidIndex(employeeIndex) ? departmentList.get(employeeIndex) : "";
  }

  public static String getPositionByIndex(int employeeIndex) {
    return isValidIndex(employeeIndex) ? positionList.get(employeeIndex) : "";
  }

  public static double getBasicSalaryByIndex(int employeeIndex) {
    return isValidIndex(employeeIndex) ? basicSalaryList.get(employeeIndex) : 0.00;
  }

  public static double getHourlyRateByIndex(int employeeIndex) {
    return isValidIndex(employeeIndex) ? hourlyRateList.get(employeeIndex) : 0.00;
  }

  public static String[] getAllEmployeeIds() {
    return employeeIdList.toArray(new String[0]);
  }

  public static int getTotalEmployeeCount() {
    return employeeIdList.size();
  }

  public static boolean doesEmployeeExist(String targetEmployeeId) {
    return findEmployeeIndexById(targetEmployeeId) != -1;
  }

  // ── Write Operations (CR02 Add, CR04 Update/Delete) ─────────────────────────

  /**
   * Adds a new employee record and immediately persists it to CSV.
   *
   * @return true if added and saved successfully; false if the ID already
   *         exists or the CSV save failed
   */
  public static boolean addNewEmployee(
      String newEmployeeId,
      String newEmployeeName,
      String newDepartment,
      String newPosition,
      double newBasicSalary,
      double newHourlyRate) {

    if (doesEmployeeExist(newEmployeeId)) {
      return false;
    }
    employeeIdList.add(newEmployeeId);
    employeeNameList.add(newEmployeeName);
    departmentList.add(newDepartment);
    positionList.add(newPosition);
    basicSalaryList.add(newBasicSalary);
    hourlyRateList.add(newHourlyRate);

    return saveToCsv();
  }

  /**
   * Updates an existing employee's mutable fields and persists to CSV.
   *
   * @return true if updated and saved; false if the employee was not found
   *         or the CSV save failed
   */
  public static boolean updateExistingEmployee(
      String targetEmployeeId,
      String updatedName,
      String updatedDepartment,
      String updatedPosition,
      double updatedBasicSalary,
      double updatedHourlyRate) {

    int targetIndex = findEmployeeIndexById(targetEmployeeId);
    if (targetIndex == -1) {
      return false;
    }
    employeeNameList.set(targetIndex, updatedName);
    departmentList.set(targetIndex, updatedDepartment);
    positionList.set(targetIndex, updatedPosition);
    basicSalaryList.set(targetIndex, updatedBasicSalary);
    hourlyRateList.set(targetIndex, updatedHourlyRate);

    return saveToCsv();
  }

  /**
   * Removes an employee record by ID and persists the change to CSV.
   *
   * @return true if removed and saved; false if not found or save failed
   */
  public static boolean deleteEmployeeById(String targetEmployeeId) {
    int targetIndex = findEmployeeIndexById(targetEmployeeId);
    if (targetIndex == -1) {
      return false;
    }
    employeeIdList.remove(targetIndex);
    employeeNameList.remove(targetIndex);
    departmentList.remove(targetIndex);
    positionList.remove(targetIndex);
    basicSalaryList.remove(targetIndex);
    hourlyRateList.remove(targetIndex);

    return saveToCsv();
  }

  // ── Display Helpers ─────────────────────────────────────────────────────────

  /** Returns a formatted table of all employee records for display. */
  public static String buildAllEmployeesDisplayTable() {
    if (employeeIdList.isEmpty()) {
      return "No employee records found.";
    }
    StringBuilder table = new StringBuilder();
    table.append(String.format("%-8s %-18s %-12s %-16s %-14s %-12s%n",
        "ID", "Name", "Department", "Position", "Basic Salary", "Hourly Rate"));
    table.append("-".repeat(85)).append("\n");

    for (int i = 0; i < employeeIdList.size(); i++) {
      table.append(String.format("%-8s %-18s %-12s %-16s PHP %-10.2f PHP %.2f%n",
          employeeIdList.get(i),
          employeeNameList.get(i),
          departmentList.get(i),
          positionList.get(i),
          basicSalaryList.get(i),
          hourlyRateList.get(i)));
    }
    return table.toString();
  }

  // ── Private Helpers ─────────────────────────────────────────────────────────

  private static boolean isValidIndex(int index) {
    return index >= 0 && index < employeeIdList.size();
  }

  private static void clearAllLists() {
    employeeIdList.clear();
    employeeNameList.clear();
    departmentList.clear();
    positionList.clear();
    basicSalaryList.clear();
    hourlyRateList.clear();
  }

  /** Builds one CSV row string for the employee at the given index. */
  private static String buildCsvRow(int index) {
    return employeeIdList.get(index) + ","
        + employeeNameList.get(index) + ","
        + departmentList.get(index) + ","
        + positionList.get(index) + ","
        + basicSalaryList.get(index) + ","
        + hourlyRateList.get(index);
  }

  /** Parses one CSV line and appends the parsed fields to the in-memory lists. */
  private static void parseAndAddCsvRow(String csvLine) {
    String[] fields = csvLine.split(",");
    if (fields.length < AppConstants.CSV_COLUMN_COUNT) {
      return; // skip malformed row rather than crash
    }
    try {
      employeeIdList.add(fields[AppConstants.CSV_INDEX_ID].trim());
      employeeNameList.add(fields[AppConstants.CSV_INDEX_NAME].trim());
      departmentList.add(fields[AppConstants.CSV_INDEX_DEPT].trim());
      positionList.add(fields[AppConstants.CSV_INDEX_POSITION].trim());
      basicSalaryList.add(Double.parseDouble(fields[AppConstants.CSV_INDEX_SALARY].trim()));
      hourlyRateList.add(Double.parseDouble(fields[AppConstants.CSV_INDEX_RATE].trim()));
    } catch (NumberFormatException numberFormatException) {
      // Skip rows with corrupted numeric fields rather than crashing the app
    }
  }

  /** Populates the in-memory lists with the default MotorPH employees. */
  private static void loadDefaultEmployees() {
    clearAllLists();
    for (int i = 0; i < AppConstants.DEFAULT_EMPLOYEE_IDS.length; i++) {
      employeeIdList.add(AppConstants.DEFAULT_EMPLOYEE_IDS[i]);
      employeeNameList.add(AppConstants.DEFAULT_EMPLOYEE_NAMES[i]);
      departmentList.add(AppConstants.DEFAULT_DEPARTMENTS[i]);
      positionList.add(AppConstants.DEFAULT_POSITIONS[i]);
      basicSalaryList.add(AppConstants.DEFAULT_BASIC_SALARIES[i]);
      hourlyRateList.add(AppConstants.DEFAULT_HOURLY_RATES[i]);
    }
  }
}
