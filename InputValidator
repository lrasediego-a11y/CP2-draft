/**
 * InputValidator
 *
 * Validation layer for all user inputs in the MotorPH Employee App.
 * Validates required fields, numeric formats, positive values,
 * employee ID existence, duplicate ID prevention, and date formats.
 *
 * Each validation method stores a descriptive error message
 * retrievable via getLastValidationError().
 */
public class InputValidator {

  private static String lastValidationError = "";

  private InputValidator() {}

  // ── Employee ID Validators ──────────────────────────────────────────────────

  public static boolean validateEmployeeIdNotEmpty(String employeeId) {
    if (employeeId == null || employeeId.trim().isEmpty()) {
      lastValidationError = "Employee Number is required. Please enter an Employee Number.";
      return false;
    }
    lastValidationError = "";
    return true;
  }

  public static boolean validateEmployeeIdExists(String employeeId) {
    if (!EmployeeData.doesEmployeeExist(employeeId)) {
      lastValidationError = buildEmployeeNotFoundMessage(employeeId);
      return false;
    }
    lastValidationError = "";
    return true;
  }

  public static boolean validateEmployeeIdIsUnique(String proposedEmployeeId) {
    if (EmployeeData.doesEmployeeExist(proposedEmployeeId)) {
      lastValidationError =
          "Employee Number " + proposedEmployeeId
          + " is already in use. Please enter a different number.";
      return false;
    }
    lastValidationError = "";
    return true;
  }

  // ── Text Field Validators ───────────────────────────────────────────────────

  /**
   * Checks that a generic text field (name, department, position) is not blank.
   *
   * @param fieldLabel display name of the field (used in error messages)
   * @param fieldValue raw input string to validate
   * @return true if non-empty; false otherwise
   */
  public static boolean validateTextFieldNotEmpty(String fieldLabel, String fieldValue) {
    if (fieldValue == null || fieldValue.trim().isEmpty()) {
      lastValidationError = fieldLabel + " is required.";
      return false;
    }
    lastValidationError = "";
    return true;
  }

  // ── Numeric Field Validators ────────────────────────────────────────────────

  public static boolean validatePositiveNumericField(String fieldLabel, String inputValue) {
    if (inputValue == null || inputValue.trim().isEmpty()) {
      lastValidationError = fieldLabel + " is required.";
      return false;
    }
    double parsedValue;
    try {
      parsedValue = Double.parseDouble(inputValue.trim());
    } catch (NumberFormatException e) {
      lastValidationError =
          fieldLabel + " must be a valid number (e.g., 25000.00). "
          + "Please remove any letters or special characters.";
      return false;
    }
    if (parsedValue <= 0) {
      lastValidationError = fieldLabel + " must be greater than zero.";
      return false;
    }
    lastValidationError = "";
    return true;
  }

  // ── Date Validators ─────────────────────────────────────────────────────────

  public static boolean validateDateField(String fieldLabel, String dateInput) {
    if (dateInput == null || dateInput.trim().isEmpty()) {
      lastValidationError = fieldLabel + " is required. Use format YYYY-MM-DD.";
      return false;
    }
    if (!dateInput.trim().matches(AppConstants.DATE_FORMAT_REGEX)) {
      lastValidationError =
          fieldLabel + " must follow the format YYYY-MM-DD (e.g., 2026-05-18).";
      return false;
    }
    try {
      String[] dateParts = dateInput.trim().split("-");
      int year  = Integer.parseInt(dateParts[0]);
      int month = Integer.parseInt(dateParts[1]);
      int day   = Integer.parseInt(dateParts[2]);

      if (year < AppConstants.DATE_YEAR_MIN || year > AppConstants.DATE_YEAR_MAX) {
        lastValidationError = fieldLabel + " year must be between "
            + AppConstants.DATE_YEAR_MIN + " and " + AppConstants.DATE_YEAR_MAX + ".";
        return false;
      }
      if (month < AppConstants.DATE_MONTH_MIN || month > AppConstants.DATE_MONTH_MAX) {
        lastValidationError = fieldLabel + " month must be between 01 and 12.";
        return false;
      }
      if (day < AppConstants.DATE_DAY_MIN || day > AppConstants.DATE_DAY_MAX) {
        lastValidationError = fieldLabel + " day must be between 01 and 31.";
        return false;
      }
    } catch (NumberFormatException e) {
      lastValidationError = fieldLabel + " contains invalid date values.";
      return false;
    }
    lastValidationError = "";
    return true;
  }

  public static boolean validatePayPeriodRange(String startDate, String endDate) {
    if (startDate.trim().compareTo(endDate.trim()) > 0) {
      lastValidationError = "Pay Period Start must be on or before Pay Period End.";
      return false;
    }
    lastValidationError = "";
    return true;
  }

  // ── Composite Validators ────────────────────────────────────────────────────

  public static boolean validatePayrollInputFields(
      String employeeId, String payCoverageStart, String payCoverageEnd) {

    if (!validateEmployeeIdNotEmpty(employeeId)) return false;
    if (!validateEmployeeIdExists(employeeId.trim())) return false;
    if (!validateDateField(AppConstants.LABEL_PAY_PERIOD_START, payCoverageStart)) return false;
    if (!validateDateField(AppConstants.LABEL_PAY_PERIOD_END, payCoverageEnd)) return false;
    if (!validatePayPeriodRange(payCoverageStart.trim(), payCoverageEnd.trim())) return false;
    return true;
  }

  /**
   * Validates all fields required to add a new employee record (Feature 2).
   *
   * @param newEmployeeId  proposed employee number
   * @param employeeName   full name
   * @param department     employee's department
   * @param position       employee's job position
   * @param basicSalaryStr raw salary string
   * @param hourlyRateStr  raw rate string
   * @return true if all fields pass; false on first failure
   */
  public static boolean validateNewEmployeeFields(
      String newEmployeeId,
      String employeeName,
      String department,
      String position,
      String basicSalaryStr,
      String hourlyRateStr) {

    if (!validateEmployeeIdNotEmpty(newEmployeeId)) return false;
    if (!validateEmployeeIdIsUnique(newEmployeeId.trim())) return false;
    if (!validateTextFieldNotEmpty(AppConstants.LABEL_EMPLOYEE_NAME, employeeName)) return false;
    if (!validateTextFieldNotEmpty(AppConstants.LABEL_DEPARTMENT, department)) return false;
    if (!validateTextFieldNotEmpty(AppConstants.LABEL_POSITION, position)) return false;
    if (!validatePositiveNumericField(AppConstants.LABEL_BASIC_SALARY, basicSalaryStr)) return false;
    if (!validatePositiveNumericField(AppConstants.LABEL_HOURLY_RATE, hourlyRateStr)) return false;
    return true;
  }

  /**
   * Validates fields required to update an existing employee record (Feature 4).
   *
   * @param updatedName        updated name
   * @param updatedDepartment  updated department
   * @param updatedPosition    updated position
   * @param updatedSalaryStr   updated salary string
   * @param updatedRateStr     updated rate string
   * @return true if all fields pass; false on first failure
   */
  public static boolean validateUpdateEmployeeFields(
      String updatedName,
      String updatedDepartment,
      String updatedPosition,
      String updatedSalaryStr,
      String updatedRateStr) {

    if (!validateTextFieldNotEmpty(AppConstants.LABEL_EMPLOYEE_NAME, updatedName)) return false;
    if (!validateTextFieldNotEmpty(AppConstants.LABEL_DEPARTMENT, updatedDepartment)) return false;
    if (!validateTextFieldNotEmpty(AppConstants.LABEL_POSITION, updatedPosition)) return false;
    if (!validatePositiveNumericField(AppConstants.LABEL_BASIC_SALARY, updatedSalaryStr)) return false;
    if (!validatePositiveNumericField(AppConstants.LABEL_HOURLY_RATE, updatedRateStr)) return false;
    return true;
  }

  // ── Error Retrieval ─────────────────────────────────────────────────────────

  public static String getLastValidationError() {
    return lastValidationError;
  }

  // ── Private Helpers ─────────────────────────────────────────────────────────

  private static String buildEmployeeNotFoundMessage(String employeeId) {
    String[] availableIds = EmployeeData.getAllEmployeeIds();
    if (availableIds.length == 0) {
      return "Employee Number \"" + employeeId
          + "\" was not found. No employees are on record.";
    }
    StringBuilder idList = new StringBuilder();
    for (int i = 0; i < availableIds.length; i++) {
      idList.append(availableIds[i]);
      if (i < availableIds.length - 1) idList.append(", ");
    }
    return "Employee Number \"" + employeeId
        + "\" was not found. Available numbers: " + idList;
  }
}
